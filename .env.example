# --- Database ---
DATABASE_URL=postgresql://user:password@host/deepfake_db

# --- Model ---
MODEL_WEIGHTS_PATH=./model_weights/efficientnet_deepfake.pth
# Download pretrained weights:
#   python scripts/download_weights.py
# Or use HuggingFace: https://huggingface.co/deepfake-detection/efficientnet-b4

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=200
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/avi,video/mov,video/webm

# --- Video Analysis ---
VIDEO_FRAMES_TO_SAMPLE=30          # number of frames extracted per video
FRAME_CONFIDENCE_THRESHOLD=0.5    # per-frame threshold

# --- API ---
API_KEY=your-secret-api-key        # optional: protect endpoints with X-API-Key header
SECRET_KEY=your-32-byte-secret
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
APP_NAME=Deepfake Detection API

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg                 # path to ffmpeg binary (or just "ffmpeg" if in PATH)
